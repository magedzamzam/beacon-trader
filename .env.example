# ---- Managed PostgreSQL (asyncpg driver). Provided at install time. ----
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/beacon

# ---- Redis (in-cluster; leave as-is for docker compose) ----
REDIS_URL=redis://redis:6379/0

# ---- Portal auth (single user). Use a long random string. ----
API_TOKEN=change-me-to-a-long-random-token

# ---- Secret used to encrypt credentials/AI keys stored in the DB ----
# Set a long random string: `openssl rand -hex 32`. If unset, API_TOKEN is used.
# Changing it later makes previously-stored encrypted secrets unreadable.
SECRET_KEY=change-me-to-a-long-random-secret

# ---- AI integrations (Anthropic Claude). Optional. ----
# Key can also be entered (encrypted) from the AI page in the portal.
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-opus-4-8

# ---- Telegram user session (mint TG_SESSION via login.py; see INSTALL.md) ----
TG_API_ID=
TG_API_HASH=
TG_SESSION=

# ---- Portal login bootstrap (optional) ----
# If set and no users exist yet, an admin user is created on API startup so you
# can sign in from any browser (no need to paste the API token each time).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---- Capital.com credentials ----
# Broker credentials are entered in the portal (Configuration -> Brokers) and
# stored encrypted in the DB. They are NOT read from .env — do not put your
# Capital.com API key / username / password here.

# ---- Tuning ----
BROKER_RATE_PER_SEC=3
MONITOR_INTERVAL=5
LOG_LEVEL=INFO

# ---- Alpha Layer / collector (Phase 0) ----
COLLECT_INTERVAL=5            # tick-capture cadence (seconds)
CANDLE_BACKFILL_BARS=1000     # 1m bars to backfill from the broker on boot
CRYPTO_MICRO_INTERVAL=60      # crypto microstructure poll (seconds)
CALENDAR_REFRESH_INTERVAL=3600
COST_PROFILE_INTERVAL=21600   # spread cost-profile rebuild (seconds; 6h)
# Swappable data sources (override to change provider):
ECON_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
BINANCE_FAPI=https://fapi.binance.com

# ---- Frontend build-time API base (browser -> api) ----
VITE_API_BASE=http://localhost:8000
